{
  "name": "studyplatform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma generate && next dev --webpack",
    "dev:turbo": "prisma generate && next dev --turbopack",
    "build": "prisma generate && next build --webpack",
    "lint": "eslint src scripts prisma eslint.config.mjs middleware.ts next.config.mjs tailwind.config.ts postcss.config.js load-public.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "start": "next start",
    "stripe": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "analytics:reconcile-download-counts": "tsx scripts/reconcile-download-counts.ts",
    "tokens:export": "tsx scripts/export-tokens-studio.ts",
    "tokens:validate": "tsx scripts/export-tokens-studio.ts --validate",
    "perf:post-deploy": "npm run warm:cache && tsx scripts/run-post-deploy-perf.ts --suite=smoke",
    "perf:ci": "npm run perf:post-deploy",
    "perf:full:prod": "tsx scripts/run-post-deploy-perf.ts --suite=full",
    "warm:cache": "tsx scripts/warm-cache.ts",
    "performance:warm": "tsx scripts/warm-public-cache.ts",
    "context:check": "node scripts/check-ai-context.mjs --worktree",
    "context:check:staged": "node scripts/check-ai-context.mjs --staged",
    "context:check:staged:strict": "node scripts/check-ai-context.mjs --staged --strict",
    "db:studio": "prisma studio",
    "ngrok": "ngrok http 3000",
    "dev:full": "concurrently \"npm run dev\"",
    "clean": "rm -rf .next",
    "reinstall": "rm -rf node_modules package-lock.json && npm install",
    "branch:retry": "git checkout main && git pull origin main && git checkout -B chore/vercel-retry",
    "push:retry": "git add . && git commit -m \"chore: vercel retry\" && git push -u origin chore/vercel-retry",
    "sync:retry": "git checkout main && git pull origin main && git checkout chore/vercel-retry && git merge main",
    "deploy": "git checkout main && git pull origin main && git merge chore/vercel-retry && git push origin main",
    "ship": "npm run push:retry && npm run deploy",
    "env:pull": "vercel env pull .env.local",
    "vercel:preview": "vercel",
    "vercel:prod": "vercel --prod"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.4.2",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.14.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@stripe/stripe-js": "^4.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.36.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.395.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.7",
    "radix-ui": "^1.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^15.0.0",
    "resend": "^6.9.4",
    "shadcn": "^4.0.3",
    "stripe": "^15.10.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "xendit-node": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "^5"
  }
}
