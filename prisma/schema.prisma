// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema  –  StudyPlatform
// Stack: PostgreSQL · NextAuth (PrismaAdapter) · Stripe
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth PrismaAdapter required tables) ───────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?   // null for OAuth-only users
  role           UserRole  @default(STUDENT)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   SubStatus @default(INACTIVE)
  subscriptionPlan     String?   // e.g. "pro_monthly"
  currentPeriodEnd     DateTime?

  // Relations
  accounts     Account[]
  sessions     Session[]
  resources    Resource[]   // resources authored by this user
  purchases    Purchase[]
  reviews      Review[]
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INACTIVE
}

// ─── Resource Library ────────────────────────────────────────────────────────

enum ResourceType {
  PDF
  DOCUMENT
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  resources   Resource[]
}

model Tag {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  resources ResourceTag[]
}

model Resource {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String         @db.Text
  type        ResourceType   @default(PDF)
  status      ResourceStatus @default(DRAFT)

  // File storage (S3 / local)
  fileUrl     String?        // URL to an external / S3-hosted file
  fileKey     String?        // key inside private-uploads/ for locally stored files
  fileSize    Int?           // bytes
  fileName    String?
  mimeType    String?
  previewUrl  String?        // thumbnail or first-page preview

  // Pricing
  isFree      Boolean  @default(false)
  price       Int      @default(0)  // in cents; 0 = free
  // If priceId is set, resource is also available via Stripe checkout
  stripePriceId       String?
  stripeProductId     String?

  // Metadata
  featured    Boolean  @default(false)
  downloadCount Int    @default(0)
  viewCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  tags        ResourceTag[]
  previews    ResourcePreview[]
  purchases   Purchase[]
  reviews     Review[]
}

model ResourceTag {
  resourceId String
  tagId      String

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
}

model ResourcePreview {
  id         String   @id @default(cuid())
  resourceId String
  imageUrl   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

// ─── Purchases ───────────────────────────────────────────────────────────────

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

model Purchase {
  id                    String         @id @default(cuid())
  userId                String
  resourceId            String
  amount                Int            // in cents (USD) or smallest unit for the currency
  currency              String         @default("usd")
  status                PurchaseStatus @default(PENDING)

  // Which payment provider processed this purchase.
  // Null on existing rows is treated as "STRIPE" in application logic.
  paymentProvider       String?        // "STRIPE" | "XENDIT"

  // ── Stripe fields ─────────────────────────────────────────────────────────
  stripeSessionId       String?        @unique
  stripePaymentIntentId String?        @unique

  // ── Xendit fields ─────────────────────────────────────────────────────────
  // xenditInvoiceId = the invoice.id returned by xendit.Invoice.createInvoice().
  // Used as the primary match key in the Xendit webhook handler, mirroring
  // the role stripeSessionId plays in the Stripe webhook handler.
  xenditInvoiceId       String?        @unique

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([userId, resourceId]) // one purchase record per user per resource
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  rating     Int      // 1–5
  body       String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([userId, resourceId])
}

// ─── Webhook Dead-letter Storage ──────────────────────────────────────────────

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String   // "STRIPE" | "XENDIT" | etc.
  eventType String   // e.g. "checkout.session.completed", "invoice.paid"
  payload   Json
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([provider, resolved, createdAt])
}
