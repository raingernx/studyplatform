// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema  –  Krukraft
// Stack: PostgreSQL · NextAuth (PrismaAdapter) · Stripe
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// ─── Auth (NextAuth PrismaAdapter required tables) ───────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum CreatorStatus {
  INACTIVE
  ACTIVE
  PAUSED
  SUSPENDED
}

enum CreatorApplicationStatus {
  NOT_APPLIED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String? // null for OAuth-only users
  role           UserRole  @default(STUDENT)
  creatorDisplayName String?
  creatorSlug        String?   @unique
  creatorBio         String?   @db.Text
  creatorBanner      String?
  creatorEnabled            Boolean                  @default(false)
  creatorStatus             CreatorStatus            @default(INACTIVE)
  creatorApplicationStatus  CreatorApplicationStatus @default(NOT_APPLIED)
  appliedAt                 DateTime?
  reviewedAt                DateTime?
  rejectionReason           String?
  creatorSocialLinks        Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   SubStatus @default(INACTIVE)
  subscriptionPlan     String? // e.g. "pro_monthly"
  currentPeriodEnd     DateTime?

  // Relations
  accounts         Account[]
  sessions         Session[]
  resources        Resource[] // resources authored by this user
  purchases        Purchase[]
  reviews          Review[]
  analyticsEvents  AnalyticsEvent[] @relation("AnalyticsEventUser")
  creatorEvents    AnalyticsEvent[] @relation("AnalyticsEventCreator")
  activityLogs     ActivityLog[]
  resourceVersions ResourceVersion[]
  auditLogs        AuditLog[]
  creatorStat      CreatorStat?
  creatorRevenue   CreatorRevenue[] @relation("CreatorRevenueCreator")
  payouts          Payout[]
  preferences      UserPreference?
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INACTIVE
}

// ─── Resource Library ────────────────────────────────────────────────────────

enum ResourceType {
  PDF
  DOCUMENT
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ResourceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ResourceLicense {
  PERSONAL_USE
  COMMERCIAL_USE
  EXTENDED_LICENSE
}

enum ResourceVisibility {
  PUBLIC
  UNLISTED
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  resources   Resource[]
}

model HomepageHero {
  id               String   @id @default(cuid())
  title            String
  subtitle         String
  primaryCtaText   String
  primaryCtaLink   String
  secondaryCtaText String?
  secondaryCtaLink String?
  badgeText        String?
  imageUrl         String?
  mediaUrl         String?
  mediaType        String?  // "image" | "gif"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PlatformSettings {
  id                     String   @id @default(cuid())
  name                   String
  description            String?
  shortName              String?
  siteUrl                String?
  defaultMetaTitle       String?
  defaultMetaDescription String?
  ogSiteName             String?
  logoUrl                String?
  logoFullUrl            String?
  logoIconUrl            String?
  logoOgUrl              String?
  logoEmailUrl           String?
  faviconUrl             String?
  supportEmail           String?
  emailSenderName        String?
  defaultLanguage        String?
  defaultCurrency        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Hero {
  id               String   @id @default(cuid())
  name             String
  type             String
  title            String
  subtitle         String?
  badgeText        String?
  primaryCtaText   String
  primaryCtaLink   String
  secondaryCtaText String?
  secondaryCtaLink String?
  imageUrl         String?
  mediaUrl         String?
  mediaType        String?
  textAlign        String?
  contentWidth     String?
  heroHeight       String?
  spacingPreset    String?
  headingFont      String?
  bodyFont         String?
  titleSize        String?
  subtitleSize     String?
  titleWeight      String?
  subtitleWeight   String?
  mobileTitleSize  String?
  mobileSubtitleSize String?
  titleColor       String?
  subtitleColor    String?
  badgeTextColor   String?
  badgeBgColor     String?
  primaryCtaVariant String?
  secondaryCtaVariant String?
  primaryCtaColor  String?
  secondaryCtaColor String?
  overlayColor     String?
  overlayOpacity   Int?
  priority         Int      @default(0)
  weight           Int      @default(1)
  isActive         Boolean  @default(true)
  startDate        DateTime?
  endDate          DateTime?
  experimentId     String?
  variant          String?
  abGroup          String?
  isFallback       Boolean  @default(false)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
  @@index([startDate])
  @@index([endDate])
}

model HeroImpression {
  id           String   @id @default(cuid())
  heroId       String
  experimentId String?
  variant      String?
  createdAt    DateTime @default(now())

  @@index([heroId, createdAt])
  @@index([experimentId, variant])
}

model HeroClick {
  id           String   @id @default(cuid())
  heroId       String
  experimentId String?
  variant      String?
  createdAt    DateTime @default(now())

  @@index([heroId, createdAt])
  @@index([experimentId, variant])
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  slug      String        @unique
  resources ResourceTag[]
}

model Resource {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String         @db.Text
  type        ResourceType   @default(PDF)
  status      ResourceStatus @default(DRAFT)

  // File storage (S3 / local)
  fileUrl    String? // URL to an external / S3-hosted file
  fileKey    String? // key inside private-uploads/ for locally stored files
  fileSize   Int? // bytes
  fileName   String?
  mimeType   String?
  previewUrl String? // thumbnail or first-page preview

  // Pricing
  isFree          Boolean @default(false)
  price           Int     @default(0) // in baht; 0 = free
  // If priceId is set, resource is also available via Stripe checkout
  stripePriceId   String?
  stripeProductId String?

  // Metadata
  featured      Boolean            @default(false)
  level         ResourceLevel?
  license       ResourceLicense?
  visibility    ResourceVisibility? // when status=PUBLISHED: PUBLIC (in listings) or UNLISTED (URL only)
  downloadCount Int                @default(0)
  viewCount     Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  authorId   String
  author     User              @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?         @relation(fields: [categoryId], references: [id])
  tags            ResourceTag[]
  previews        ResourcePreview[]
  purchases       Purchase[]
  reviews         Review[]
  versions        ResourceVersion[]
  downloadEvents  DownloadEvent[]
  analyticsEvents AnalyticsEvent[]
  resourceStat    ResourceStat?
  creatorRevenue  CreatorRevenue[] @relation("CreatorRevenueResource")
  aiDraft         ResourceAIDraft?

  // Indexes for common marketplace listing queries
  @@index([status, createdAt])
  @@index([status, downloadCount])
  @@index([status, featured])
  @@index([status, isFree, createdAt])
  // Category-filtered listing queries (sort=newest, sort=trending, sort=downloads, etc.)
  @@index([status, categoryId, createdAt])
  @@index([status, categoryId, downloadCount])
  @@index([status, categoryId, featured])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([authorId, deletedAt, createdAt])
}

model ResourceAIDraft {
  id               String   @id @default(cuid())
  resourceId       String   @unique
  sourceText       String   @db.Text
  sourceFileName   String?
  subject          String?
  grade            String?
  language         String   @default("th")
  quizCount        Int      @default(5)
  summary          String   @db.Text
  learningOutcomes String   @db.Text
  quizDraft        String   @db.Text
  generationMode   String   @default("HEURISTIC_V1")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model ResourceVersion {
  id         String @id @default(cuid())
  resourceId String
  version    Int

  // File snapshot at this version
  fileKey  String?
  fileName String?
  fileSize Int?
  mimeType String?
  fileUrl  String?

  changelog String? @db.Text

  createdAt   DateTime @default(now())
  createdById String?

  resource  Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])

  @@unique([resourceId, version])
  @@index([resourceId, version])
}

model ResourceTag {
  resourceId String
  tagId      String

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
}

model ResourcePreview {
  id         String   @id @default(cuid())
  resourceId String
  imageUrl   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

// ─── Purchases ───────────────────────────────────────────────────────────────

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

model Purchase {
  id         String         @id @default(cuid())
  userId     String
  resourceId String
  amount     Int // in smallest currency unit (e.g. satang for THB)
  currency   String         @default("usd")
  status     PurchaseStatus @default(PENDING)
  authorId   String?
  authorRevenue Int?

  // Which payment provider processed this purchase.
  // Null on existing rows is treated as "STRIPE" in application logic.
  paymentProvider String? // "STRIPE" | "XENDIT"

  // ── Stripe fields ─────────────────────────────────────────────────────────
  stripeSessionId       String? @unique
  stripePaymentIntentId String? @unique

  // ── Xendit fields ─────────────────────────────────────────────────────────
  // xenditInvoiceId = the invoice.id returned by xendit.Invoice.createInvoice().
  // Used as the primary match key in the Xendit webhook handler, mirroring
  // the role stripeSessionId plays in the Stripe webhook handler.
  xenditInvoiceId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])
  creatorRevenue CreatorRevenue?

  @@unique([userId, resourceId]) // one purchase record per user per resource
  @@index([userId, status])
  @@index([resourceId])
  @@index([status, createdAt])
  @@index([authorId, createdAt])
}

model Payout {
  id        String   @id @default(cuid())
  authorId  String
  amount    Int
  status    String
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt])
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  rating     Int // 1–5
  isVisible  Boolean  @default(true)
  body       String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([userId, resourceId])
  @@index([resourceId, isVisible, createdAt])
}

// ─── User Preferences ──────────────────────────────────────────────────────────

model UserPreference {
  id      String @id @default(cuid())
  userId  String @unique

  language String @default("th")
  theme    String @default("light")
  currency String @default("THB")
  timezone String @default("Asia/Bangkok")

  // Notification preferences (can be expanded over time)
  emailNotifications  Boolean @default(true)
  purchaseReceipts    Boolean @default(true)
  productUpdates      Boolean @default(true)
  marketingEmails     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Webhook Dead-letter Storage ──────────────────────────────────────────────

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String // "STRIPE" | "XENDIT" | etc.
  eventType String // e.g. "checkout.session.completed", "invoice.paid"
  payload   Json
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([provider, resolved, createdAt])
}

// ─── Activity Log ───────────────────────────────────────────────────────────────

model ActivityLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action   String
  entity   String?
  entityId String?

  metadata Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([action, entity])
}

// ─── Admin Audit Trail ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entityType String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action])
  @@index([entityType])
}

// ─── Download Events ──────────────────────────────────────────────────────────
//
// One row per successful file delivery.  Used for analytics dashboards and
// per-resource download trend charts.  Supplements the downloadCount counter
// on the Resource model which is also maintained for fast sorting/ordering.
//
// userId is nullable so future unauthenticated/guest downloads can also be
// recorded.  The relation to User is intentionally omitted — the userId here
// is a soft reference (no FK constraint) to keep the write fast and to avoid
// cascading deletes when users are removed.

model DownloadEvent {
  id         String   @id @default(cuid())
  resourceId String
  userId     String?  // null = unauthenticated; soft reference, no FK
  ip         String?  // client IP from cf-connecting-ip / x-forwarded-for

  createdAt  DateTime @default(now())

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([createdAt])
  @@index([resourceId, createdAt])
  @@index([userId])
}

enum AnalyticsEventType {
  RESOURCE_VIEW
  RESOURCE_DOWNLOAD
  RESOURCE_PURCHASE
  RESOURCE_LIKE
  RESOURCE_BOOKMARK
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  eventType  AnalyticsEventType
  userId     String?
  resourceId String?
  creatorId  String?
  metadata   Json?
  createdAt  DateTime           @default(now())

  user     User?     @relation("AnalyticsEventUser", fields: [userId], references: [id], onDelete: SetNull)
  resource Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  creator  User?     @relation("AnalyticsEventCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([resourceId, createdAt])
  @@index([creatorId, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

model ResourceStat {
  resourceId         String   @id
  views              Int      @default(0)
  downloads          Int      @default(0)
  purchases          Int      @default(0)
  revenue            Int      @default(0)
  last24hDownloads   Int      @default(0)
  last7dDownloads    Int      @default(0)
  last30dDownloads   Int      @default(0)
  last24hPurchases   Int      @default(0)
  last7dPurchases    Int      @default(0)
  last30dPurchases   Int      @default(0)
  trendingScore      Int      @default(0)
  updatedAt          DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([trendingScore, updatedAt])
  @@index([downloads, updatedAt])
  @@index([purchases, updatedAt])
  @@map("resource_stats")
}

model CreatorStat {
  creatorId       String   @id
  resources       Int      @default(0)
  totalDownloads  Int      @default(0)
  last30dDownloads Int     @default(0)
  totalSales      Int      @default(0)
  totalRevenue    Int      @default(0)
  last7dRevenue   Int      @default(0)
  last30dRevenue  Int      @default(0)
  updatedAt       DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([totalRevenue, updatedAt])
  @@index([totalDownloads, updatedAt])
  @@map("creator_stats")
}

model PlatformStat {
  date           DateTime @id @db.Date
  totalDownloads Int      @default(0)
  totalSales     Int      @default(0)
  totalRevenue   Int      @default(0)
  newUsers       Int      @default(0)
  newResources   Int      @default(0)

  @@map("platform_stats")
}

model CreatorRevenue {
  id           String   @id @default(cuid())
  creatorId    String
  resourceId   String
  purchaseId   String   @unique
  amount       Int
  platformFee  Int
  creatorShare Int
  createdAt    DateTime @default(now())

  creator  User     @relation("CreatorRevenueCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  resource Resource @relation("CreatorRevenueResource", fields: [resourceId], references: [id], onDelete: Cascade)
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@index([resourceId, createdAt])
  @@map("creator_revenue")
}
