# ─────────────────────────────────────────────────────────────────────────────
# PaperDock — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-secret   # openssl rand -base64 32

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/studyplatform?schema=public"

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription Price IDs from your Stripe dashboard
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
# Required for production. Without these, the app falls back to LocalStorageProvider
# (ephemeral filesystem — not suitable for serverless deployments).
#
# How to set up:
#   1. Create a bucket in the Cloudflare dashboard → R2 → Create bucket
#   2. Create an API token: R2 → Manage R2 API Tokens → Create Token
#      Permissions required: Object Read & Write on your bucket
#   3. The endpoint is: https://<account-id>.r2.cloudflarestorage.com
#      Find your account ID in the Cloudflare dashboard URL or R2 overview.
#
# R2 endpoint — https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# R2 bucket name (e.g. paperdock-files)
R2_BUCKET=paperdock-files

# R2 API token credentials
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: custom domain or public URL for the bucket (e.g. https://files.paperdock.com)
# Only needed if the bucket has public access enabled.
# Used by getUrl() for admin previews. Downloads always use presigned URLs.
R2_PUBLIC_URL=

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
# Required for production rate limiting (checkout, download, upload endpoints).
# Without these, rate limiting is disabled and all requests are allowed.
# Create a database at https://console.upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
